# AetherGate — variables d'exemple (sans secrets réels)

PRODUCT_NAME=AetherGate

# --- Clés fournisseurs ---
OPENAI_API_KEY=
HF_TOKEN=
ANTHROPIC_API_KEY=

# --- PostgreSQL ---
POSTGRES_USER=aethergate
POSTGRES_PASSWORD=CHANGE_ME_STRONG

# --- LiteLLM ---
LITELLM_MASTER_KEY=sk-CHANGE_ME
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=CHANGE_ME
LITELLM_BASE_URL=http://localhost:4000
LITELLM_OAUTH_CLIENT_ID=aethergate-litellm
LITELLM_OAUTH_CLIENT_SECRET=CHANGE_ME

# --- Open WebUI ---
WEBUI_SECRET_KEY=CHANGE_ME
OPENWEBUI_BASE_URL=http://localhost:3000
OPENWEBUI_OAUTH_CLIENT_ID=aethergate-openwebui
OPENWEBUI_OAUTH_CLIENT_SECRET=CHANGE_ME

# --- Authentik SSO ---
AUTHENTIK_SECRET_KEY=CHANGE_ME
AUTHENTIK_PUBLIC_URL=http://host.docker.internal:9000
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=CHANGE_ME
AUTHENTIK_BOOTSTRAP_TOKEN=CHANGE_ME

# --- Grand Admin (FastAPI) ---
ADMIN_USERNAME=grandadmin
ADMIN_PASSWORD=CHANGE_ME
ADMIN_ALERT_WEBHOOK=
ADMIN_MONITOR_SECONDS=60

# --- Ollama ---
OLLAMA_PULL_MODEL=llama3.2

# --- Production (docker-compose.prod.yml) ---
# DOMAIN=example.com
# ACME_EMAIL=ops@example.com
